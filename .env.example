# Copy to .env. Compose reads this automatically.
# Anything left blank uses the defaults baked into docker-compose.yml.

# Postgres (rotate before any non-local deployment)
POSTGRES_PASSWORD=postgres

# JWT signing key — MUST be at least 32 chars. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=dev-secret-replace-with-32+char-random-via-env-please

# AI provider:
#   Mock        → deterministic in-process orchestrator (works without Azure)
#   AzureOpenAi → real Semantic Kernel + Azure OpenAI chat completion
AI_PROVIDER=Mock
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Embeddings deployment for the RAG pipeline. Leave blank to fall back to the
# deterministic in-process hashing embedder (RAG still works, just without true
# semantic recall). text-embedding-3-small is recommended for cost/latency.
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# RAG tuning. Defaults are tuned for the demo corpus (~13 docs, 1536-dim vectors).
AI_RAG_ENABLED=true
AI_RAG_TOPK=5
AI_RAG_EMBEDDING_DIMENSIONS=1536

# .NET environment — flip to Production once you wire real secrets above
ASPNETCORE_ENVIRONMENT=Development
